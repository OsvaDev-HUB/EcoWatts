# Configuración de Base de Datos (Local Docker o Supabase)
# Local: postgresql://ecowatts_user:EcoWatts_SecurePass2025!@localhost:5432/Eco_Watts
# Supabase: postgresql://postgres.[PROYECTO]:[PASSWORD]@[HOST]:[PUERTO]/postgres
DATABASE_URL=postgresql://usuario:password@localhost:5432/nombre_db

# Variables Docker Compose
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_password
POSTGRES_DB=Eco_Watts

# Secreto para sesiones de Flask
# Genera uno fuerte con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiame_por_un_secreto_seguro
